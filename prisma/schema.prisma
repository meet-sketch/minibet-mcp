generator client {
    provider = "prisma-client-js"
    output   = "../node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model tbl_accounts {
    airbyte_raw_id        String    @map("_airbyte_raw_id") @db.VarChar
    airbyte_extracted_at  DateTime  @map("_airbyte_extracted_at") @db.Timestamptz(6)
    airbyte_meta          Json      @map("_airbyte_meta")
    airbyte_generation_id BigInt    @map("_airbyte_generation_id")
    id                    String    @id @default(uuid()) @db.Char(36)
    user_id               String?   @db.VarChar
    created_at            DateTime? @db.Timestamp(6)
    updated_at            DateTime? @db.Timestamp(6)
    affiliate_code        String?   @db.VarChar
    plan_config_id        String?   @db.VarChar
    organization_id       String?   @db.VarChar

    @@index([updated_at], map: "idx_cursor_tbl_accounts")
    @@index([airbyte_extracted_at], map: "idx_extracted_at_tbl_accounts")
    @@index([id], map: "idx_pk_tbl_accounts")
}

